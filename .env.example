# ============================================================
# BASE DE DONNÉES
# ============================================================
DATABASE_URL=postgresql://user:password@localhost:5432/nova_studio
DIRECT_URL=postgresql://user:password@localhost:5432/nova_studio

# ============================================================
# AUTHENTIFICATION
# ============================================================
NEXTAUTH_SECRET=your-secret-here-min-32-chars-long
NEXTAUTH_URL=http://localhost:3000

# Discord OAuth
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# ============================================================
# DISCORD BOT
# ============================================================
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=

# Salon IDs
DISCORD_CHANNEL_CANDIDATURES=
DISCORD_CHANNEL_DEMANDES=
DISCORD_CHANNEL_BOT_LOGS=

# Role IDs
DISCORD_ROLE_ADMIN=
DISCORD_ROLE_CREATOR=
DISCORD_ROLE_MONTEUR=
DISCORD_ROLE_3D=
DISCORD_ROLE_DEV=
DISCORD_ROLE_SOUND=
DISCORD_ROLE_GRAPHISTE=
DISCORD_ROLE_TRADUCTEUR=
DISCORD_ROLE_DISCORD_BUILDER=

# ============================================================
# API INTERNE
# ============================================================
INTERNAL_API_KEY=your-internal-api-key-64-chars
INTERNAL_API_URL=http://localhost:3000/api/internal

# Bot HTTP server
BOT_HTTP_PORT=4000
BOT_HTTP_URL=http://localhost:4000

# ============================================================
# EMAIL
# ============================================================
RESEND_API_KEY=re_your_key_here
EMAIL_FROM="Nova Studio <noreply@novastudio.com>"

# ============================================================
# PAIEMENTS
# ============================================================
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ============================================================
# STOCKAGE FICHIERS
# ============================================================
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=nova-studio-files
R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
NEXT_PUBLIC_R2_PUBLIC_URL=https://files.novastudio.com

# ============================================================
# TEMPS RÉEL
# ============================================================
NEXT_PUBLIC_SOCKET_URL=http://localhost:3001
SOCKET_PORT=3001

# ============================================================
# REDIS
# ============================================================
REDIS_URL=redis://localhost:6379

# ============================================================
# CRON
# ============================================================
CRON_SECRET=your-cron-secret

# ============================================================
# MONITORING
# ============================================================
SENTRY_DSN=
