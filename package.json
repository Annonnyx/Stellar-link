{
  "name": "nova-studio",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "db:push": "pnpm --filter @nova-studio/database db:push",
    "db:generate": "pnpm --filter @nova-studio/database db:generate",
    "db:migrate": "pnpm --filter @nova-studio/database db:migrate",
    "db:seed": "pnpm --filter @nova-studio/database db:seed",
    "db:studio": "pnpm --filter @nova-studio/database db:studio",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\""
  },
  "devDependencies": {
    "prettier": "^3.3.0",
    "turbo": "^2.3.0",
    "typescript": "^5.6.0"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=22.0.0"
  }
}
